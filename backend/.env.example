# Copia este fichero a .env y rellena los valores. NUNCA subas .env al repo.
APP_ENV=dev
DATABASE_URL=postgresql+psycopg://series:series@localhost:5432/series_tracker

# JWT — genera uno con: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me
JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=30

# TMDB API v4 (Bearer token) — https://www.themoviedb.org/settings/api
TMDB_BEARER_TOKEN=your-tmdb-v4-read-access-token
TMDB_BASE_URL=https://api.themoviedb.org/3

# CORS: orígenes del frontend permitidos (separados por coma)
CORS_ORIGINS=http://localhost:5173
